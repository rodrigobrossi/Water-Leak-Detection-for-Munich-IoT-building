# Raspberry Pi Sensor — Environment Variables
# Copy this file to .env, fill in your values, then run:
#   source .env && python humidity.py

# IBM Watson IoT Platform credentials
IOT_ORG=your_org_id
IOT_DEVICE_TYPE=waterLeakDetector
IOT_DEVICE_ID=your_device_id
IOT_TOKEN=your_auth_token

# Blynk App Token (from Project Settings in the Blynk app)
BLYNK_TOKEN=your_blynk_token
